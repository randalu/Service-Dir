<?php
require_once __DIR__ . '/includes/config.php';
require_once __DIR__ . '/db.php';

header('Content-Type: application/xml; charset=utf-8');

$services = $pdo->query("SELECT id, created_at FROM services ORDER BY id DESC")->fetchAll();
$categories = $pdo->query("SELECT id FROM categories ORDER BY id")->fetchAll();

echo '<?xml version="1.0" encoding="UTF-8"?>';
?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><?= APP_URL ?>/index.php</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <?php foreach ($categories as $cat): ?>
  <url>
    <loc><?= APP_URL ?>/category.php?id=<?= $cat['id'] ?></loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <?php endforeach; ?>
  <?php foreach ($services as $s): ?>
  <url>
    <loc><?= APP_URL ?>/service_view.php?id=<?= $s['id'] ?></loc>
    <lastmod><?= date('c', strtotime($s['created_at'])) ?></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <?php endforeach; ?>
</urlset>
